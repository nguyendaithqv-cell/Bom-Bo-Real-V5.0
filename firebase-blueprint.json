{
  "entities": {
    "Conversation": {
      "title": "Conversation",
      "description": "A chat session between a user and the AI assistant.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Unique identifier for the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of when the conversation started." },
        "messages": {
          "type": "array",
          "description": "List of messages in the conversation.",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "ai"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["userId", "createdAt", "messages"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Information about a customer who interacted with the chatbot.",
      "type": "object",
      "properties": {
        "phoneNumber": { "type": "string" },
        "name": { "type": "string" },
        "lastContacted": { "type": "string", "format": "date-time" }
      },
      "required": ["phoneNumber"]
    },
    "VisitorLog": {
      "title": "VisitorLog",
      "description": "Tracks visitor activity and contact information.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "lastVisited": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "device": { "type": "string" },
        "viewedPlots": { "type": "array", "items": { "type": "string" } },
        "pageHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pageUrl": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["visitorId", "lastVisited", "viewedPlots", "pageHistory"]
    },
    "Consignment": {
      "title": "Consignment",
      "description": "Real estate consignment information submitted by customers.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "zalo": { "type": "string" },
        "propertyType": { "type": "string" },
        "address": { "type": "string" },
        "area": { "type": "string" },
        "dimensions": { "type": "string" },
        "price": { "type": "string" },
        "legalStatus": { "type": "string" },
        "direction": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["fullName", "phoneNumber", "propertyType", "address", "price", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact form submissions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["name", "phone", "message", "createdAt"]
    },
    "Offer": {
      "title": "Offer",
      "description": "Price offers for land plots.",
      "type": "object",
      "properties": {
        "plotId": { "type": "string" },
        "originalPrice": { "type": "number" },
        "offeredPrice": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["plotId", "phone", "offeredPrice", "createdAt"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "showBombo": { "type": "boolean", "description": "Whether to show Thái Thành Bom Bo products." },
        "showOther": { "type": "boolean", "description": "Whether to show other products." },
        "hotline": { "type": "string", "description": "Main contact hotline." },
        "zaloLink": { "type": "string", "description": "Link to Zalo contact." },
        "facebookLink": { "type": "string", "description": "Link to Facebook page." },
        "officeAddress": { "type": "string", "description": "Physical office address." },
        "marqueeText": { "type": "string", "description": "Scrolling announcement text." },
        "showMarquee": { "type": "boolean", "description": "Whether to show the marquee." },
        "showPopup": { "type": "boolean", "description": "Whether to show a popup notification." },
        "popupContent": { "type": "string", "description": "Content of the popup notification." },
        "enableAIChat": { "type": "boolean", "description": "Enable/disable AI Chatbot." },
        "enableConsignment": { "type": "boolean", "description": "Enable/disable Consignment feature." },
        "enableOffers": { "type": "boolean", "description": "Enable/disable Price Offer feature." },
        "heroImageUrl": { "type": "string", "description": "URL for the main hero image." },
        "maintenanceMode": { "type": "boolean", "description": "Enable/disable maintenance mode." },
        "telegramBotToken": { "type": "string", "description": "Telegram Bot API Token." },
        "telegramChatId": { "type": "string", "description": "Telegram Chat ID to receive notifications." },
        "enableTelegramNotify": { "type": "boolean", "description": "Enable/disable Telegram notifications." },
        "mainTitle": { "type": "string", "description": "Main title on the home page." },
        "subTitle": { "type": "string", "description": "Sub title on the home page." }
      },
      "required": ["showBombo", "showOther", "hotline", "enableAIChat", "enableConsignment", "enableOffers", "maintenanceMode", "enableTelegramNotify"]
    }
  },
  "firestore": {
    "/consignments/{consignmentId}": {
      "schema": { "$ref": "Consignment" },
      "description": "Stores real estate consignment submissions."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "Conversation" },
      "description": "Stores individual chat sessions."
    },
    "/customers/{phoneNumber}": {
      "schema": { "$ref": "Customer" },
      "description": "Stores customer contact information."
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "Contact" },
      "description": "Stores contact form submissions."
    },
    "/offers/{offerId}": {
      "schema": { "$ref": "Offer" },
      "description": "Stores price offers for land plots."
    },
    "/visitor_logs/{visitorId}": {
      "schema": { "$ref": "VisitorLog" },
      "description": "Tracks visitor activity and contact information."
    },
    "/app_settings/{settingId}": {
      "schema": { "$ref": "AppSettings" },
      "description": "Stores global application settings."
    }
  }
}
